# plugin manager
SHELDON_CONFIG_DIR="$ZDOTDIR/sheldon"
eval "$(sheldon source)"

# alias
alias rm='rm -I --preserve-root'
alias mv='mv -i'
alias cp='cp -i'
alias ln='ln -i'
alias chown='chown --preserve-root'
alias chmod='chmod --preserve-root'
alias chgrp='chgrp --preserve-root'
alias ls='ls --color=auto'

# abbr
export ABBR_SET_EXPANSION_CURSOR=1
abbr -S ncg='nix-collect-garbage -d' > /dev/null
abbr -S ..='cd ..' > /dev/null
abbr -S ...='cd ../../' > /dev/null

abbr -S d='docker' > /dev/null
abbr -S dc='docker compose' > /dev/null
abbr -S dcu='docker compose up' > /dev/null
abbr -S dcud='docker compose up -d' > /dev/null
abbr -S dcd='docker compose down' > /dev/null
abbr -S dcp='docker compose ps' > /dev/null
abbr -S dcl='docker compose logs' > /dev/null
abbr -S dce='docker compose exec' > /dev/null
abbr -S dcr='docker compose restart' > /dev/null

abbr -S g='git' > /dev/null
abbr -S ga='git add' > /dev/null
abbr -S ga.='git add .' > /dev/null
abbr -S gcm='git commit -m "%"' > /dev/null
abbr -S gco='git checkout %' > /dev/null
abbr -S gst='git status' > /dev/null
abbr -S gl='git log --oneline --graph --decorate --all' > /dev/null
abbr -S gf='git fetch' > /dev/null
abbr -S gp='git pull' > /dev/null
abbr -S gP='git push' > /dev/null
abbr -S gsw='git switch' > /dev/null

# ls
if command -v eza >/dev/null 2>&1; then
  abbr -S l='eza -F --group-directories-first' > /dev/null
  abbr -S la='eza -aF --group-directories-first' > /dev/null
  abbr -S ll='eza -lahF --icons=auto --git --group-directories-first' > /dev/null
else
  abbr -S l='ls -F' > /dev/null
  abbr -S la='ls -aF' > /dev/null
  abbr -S ll='ls -lahF' > /dev/null
fi

# history
HISTFILE="$XDG_STATE_HOME/zsh_history"
HISTSIZE=100000
SAVEHIST=100000
setopt share_history
setopt hist_ignore_space
setopt hist_reduce_blanks
setopt inc_append_history

# completion
zstyle ':completion:*' matcher-list 'm:{a-z}={A-Z}'

# starchip
eval "$(starship init zsh)"

# direnv
eval "$(direnv hook zsh)"

# zoxide
eval "$(zoxide init zsh)"

# fzf
source <(fzf --zsh)

export PATH="$HOME/.local/bin:$PATH"
export EDITOR="nvim"

bindkey -v
bindkey '^f' autosuggest-accept

